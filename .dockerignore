# .dockerignore — what NOT to send to the docker build context.
#
# Dockerfile only COPYs `requirements.lock`, `src/`, and `main.py`, so most
# of what we exclude here is just to keep the build context small (faster
# uploads to remote builders, smaller layer cache keys). When in doubt,
# add the path here rather than relying on the Dockerfile's COPY scope.

# Version control
.git/
.gitignore
.gitattributes

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# Test / type-check caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Environment / secrets
.env
.env.*
*.pem
*.key
*.crt
secrets/

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Docs and tools — not needed at runtime
README.md
ARCHITECTURE.md
ROADMAP.md
CLAUDE.md
docs/
tools/

# Build artifacts
*.tar.gz
*.tgz
*.whl

# CI metadata
.gitlab-ci.yml
.github/
